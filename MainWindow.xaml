<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema" Height="600" Width="900"
        WindowState="Maximized">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Título -->
            <TextBlock Text="Sistema de Gestão"
                       FontSize="28" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Selecione um módulo para começar"
                       FontSize="13"
                       Foreground="#aaaacc"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Botões -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button Click="BtnPessoas_Click" Width="160" Height="100" Margin="10"
                        Cursor="Hand" Background="#e94560" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="👤" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Pessoas" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnProdutos_Click" Width="160" Height="100" Margin="10"
                        Cursor="Hand" Background="#0f8a5f" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Produtos" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnPedidos_Click" Width="160" Height="100" Margin="10"
                        Cursor="Hand" Background="#e8a020" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🧾" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Pedidos" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
